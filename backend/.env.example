DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Use postgres for the target stack. Set DB_ENGINE=sqlite only for quick local checks.
DB_ENGINE=postgres
POSTGRES_DB=welding_control
POSTGRES_USER=welding_control
POSTGRES_PASSWORD=welding_control
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Switch to s3 when MinIO/S3 is configured.
STORAGE_BACKEND=local
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=welding-control
AWS_S3_ENDPOINT_URL=http://127.0.0.1:9000
