<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#05070a">

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        app:scaleType="fillCenter" />

    <com.weldingdefect.MaskOverlayView
        android:id="@+id/maskOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#05070a" />

    <View
        android:layout_width="match_parent"
        android:layout_height="156dp"
        android:layout_gravity="top"
        android:background="@drawable/top_scrim" />

    <View
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bottom_scrim" />

    <LinearLayout
        android:id="@+id/topPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingTop="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="10dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:shadowColor="#aa000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="5"
                android:text="@string/screen_title"
                android:textColor="#ffffff"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:shadowColor="#aa000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="4"
                android:text="@string/status_ready"
                android:textColor="#e5e7eb"
                android:textSize="13sp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTorch"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="12dp"
            android:contentDescription="@string/torch"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:text="⚡"
            android:textAllCaps="false"
            android:textColor="#ffffff"
            android:textSize="22sp"
            android:visibility="gone"
            app:backgroundTint="#66000000"
            app:cornerRadius="24dp"
            app:strokeColor="#55ffffff"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClose"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="12dp"
            android:contentDescription="@string/close_photo"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:text="×"
            android:textAllCaps="false"
            android:textColor="#ffffff"
            android:textSize="28sp"
            android:visibility="gone"
            app:backgroundTint="#66000000"
            app:cornerRadius="24dp"
            app:strokeColor="#55ffffff"
            app:strokeWidth="1dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvZoom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="84dp"
        android:layout_marginEnd="22dp"
        android:shadowColor="#aa000000"
        android:shadowDx="0"
        android:shadowDy="1"
        android:shadowRadius="4"
        android:text="1.0x"
        android:textColor="#ffffff"
        android:textSize="14sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/resultPanel"
        android:layout_width="match_parent"
        android:layout_height="112dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="112dp"
        android:background="@drawable/result_sheet"
        android:clickable="true"
        android:focusable="true"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="14dp"
        android:paddingEnd="20dp"
        android:paddingBottom="14dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvResultHeadline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/result_title"
            android:textColor="#ffffff"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="6dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:overScrollMode="never">

            <TextView
                android:id="@+id/tvDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="2dp"
                android:textColor="#d1d5db"
                android:textSize="14sp" />
        </ScrollView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="match_parent"
        android:layout_height="112dp"
        android:layout_gravity="bottom"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingBottom="22dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPickGallery"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/pick_gallery"
            android:textAllCaps="false"
            android:textColor="#ffffff"
            app:backgroundTint="#66000000"
            app:cornerRadius="24dp"
            app:strokeColor="#66ffffff"
            app:strokeWidth="1dp" />

        <FrameLayout
            android:id="@+id/captureButtonContainer"
            android:layout_width="96dp"
            android:layout_height="78dp"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTakePhoto"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_gravity="center"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:text=""
                android:textAllCaps="false"
                app:backgroundTint="#00ffffff"
                app:cornerRadius="36dp"
                app:strokeColor="#ffffff"
                app:strokeWidth="5dp" />

            <View
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_gravity="center"
                android:background="@drawable/capture_inner"
                android:clickable="false"
                android:focusable="false" />
        </FrameLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRun"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="@string/run_segmentation"
            android:textAllCaps="false"
            android:textColor="#ffffff"
            android:visibility="invisible"
            app:backgroundTint="#d9111827"
            app:cornerRadius="26dp" />
    </LinearLayout>

</FrameLayout>
